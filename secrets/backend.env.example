# Copy to backend.env and fill in real values.
# DATABASE_URL for Docker Compose (host = db):
DATABASE_URL=postgresql+psycopg2://webspam:change-me-strong@db:5432/webspam

# Local dev (only backend on host, Postgres in Docker): use localhost
# DATABASE_URL=postgresql+psycopg2://webspam:change-me-strong@localhost:5432/webspam

JWT_SECRET=generate-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# First launch: create admin if no users exist
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-admin-password

# SMTP (example: m.krasnodar.ru)
SMTP_HOST=m.krasnodar.ru
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=WebSpamming
SMTP_USE_TLS=true
# Порт 465 (implicit SSL): SMTP_USE_SSL=true и обычно SMTP_USE_TLS=false
SMTP_USE_SSL=false

# Автосоздание списка "По умолчанию" из подпапок (имя папки = email).
DEFAULT_MAILING_BOOTSTRAP_ENABLED=true
DEFAULT_MAILING_LIST_NAME=По умолчанию
# В docker-compose монтируется как /data/default-email (из S:/УСЗН Хоста/Email)
DEFAULT_MAILING_SOURCE_DIR=/data/default-email

# Dev: allow any origin for CORS (LAN testing). Set false in production.
CORS_ALLOW_ALL=true

# API bind (inside container always 0.0.0.0 via Dockerfile)
API_HOST=0.0.0.0
API_PORT=8000
